<?xml version="1.0" encoding="utf-8"?>
<!-- Square grid cell. Width is set dynamically by GridLayoutManager; height = width via SquareImageView. -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/cell_gap">

    <com.oxoghost.hexapic.ui.library.SquareImageView
        android:id="@+id/thumbnail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- Video badge: play icon + duration (bottom-left, semi-transparent bg) -->
    <LinearLayout
        android:id="@+id/video_badge_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/bg_badge"
        android:paddingHorizontal="3dp"
        android:paddingVertical="2dp">

        <ImageView
            android:id="@+id/video_icon"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:src="@drawable/ic_video_badge"
            android:visibility="gone"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/video_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Favorite heart badge (bottom-right) -->
    <ImageView
        android:id="@+id/iv_favorite"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="4dp"
        android:src="@drawable/ic_favorite"
        android:background="@drawable/bg_badge"
        android:padding="3dp"
        android:visibility="gone"
        android:contentDescription="@null" />

</FrameLayout>
